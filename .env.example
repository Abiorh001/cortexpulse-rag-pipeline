OPENAI_API_KEY=your_openai_api_key_here

# Optional. If omitted or unavailable, the app uses bundled sample articles.
GUARDIAN_API_KEY=

OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cortexpulse_news
GUARDIAN_QUERY=artificial intelligence
MAX_ARTICLES=1
CHUNK_SIZE=400
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=4
CITATION_SNIPPET_CHARS=260
CONTEXTUALIZATION_ENABLED=false
OPENAI_ANSWER_TEMPERATURE=0.2
OPENAI_CONTEXTUALIZE_TEMPERATURE=0
MAX_ARTICLE_CONTEXT_CHARS=6000
CONTEXTUALIZATION_CONCURRENCY=2
REQUEST_TIMEOUT_SECONDS=20
RETRY_ATTEMPTS=3
RETRY_INITIAL_BACKOFF_SECONDS=0.75
RETRY_BACKOFF_MULTIPLIER=2
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RESET_SECONDS=30
